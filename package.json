{
  "name": "@stagetimerio/google-secrets",
  "version": "0.7.2",
  "description": "Load secrets from Google Cloud Secret Manager into environment variables, similar to dotenv",
  "license": "ISC",
  "author": "Lukas Hermann <hey@lukashermann.dev>",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./load": {
      "import": {
        "types": "./dist/load.d.mts",
        "default": "./dist/load.mjs"
      },
      "require": {
        "types": "./dist/load.d.cts",
        "default": "./dist/load.cjs"
      }
    }
  },
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "google cloud",
    "secret manager",
    "environment variables",
    "dotenv",
    "secrets"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@google-cloud/secret-manager": "^6.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "rolldown": {
      "typescript": "$typescript"
    }
  }
}
